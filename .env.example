# Copy to .env and fill in your keys. Never commit the real .env.
# The demo loads this file from the repo root via python-dotenv.

# Which provider the demo's LLM_AUDIT uses: "anthropic" (default), "openai", or "ollama".
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_LLM_MODEL=claude-haiku-4-5-20251001   # optional; this is the default

# OpenAI (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_key_here
# OPENAI_LLM_MODEL=gpt-4o-mini                     # optional; this is the default

# Ollama / local models (used when LLM_PROVIDER=ollama) — no API key needed.
# Requires `ollama serve` running and the model pulled (`ollama pull llama3.1`).
# OLLAMA_LLM_MODEL=llama3.1                         # optional; this is the default
# OLLAMA_HOST=http://localhost:11434               # optional; this is the default
